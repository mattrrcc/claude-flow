{
  "expo": {
    "name": "Rebel Reaper",
    "slug": "rebel-reaper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rebelreaper.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan barcodes and take product photos.",
        "NSPhotoLibraryUsageDescription": "Used to upload profile photos.",
        "NSFaceIDUsageDescription": "Used for secure authentication."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.rebelreaper.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image",
      [
        "expo-haptics",
        {}
      ],
      [
        "react-native-reanimated",
        {}
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "rebel-reaper-project-id"
      }
    },
    "owner": "rebelreaper",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/rebel-reaper-project-id"
    }
  }
}
